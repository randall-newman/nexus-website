# Copy to .env.local for development. In Vercel, set these under
# Project Settings → Environment Variables for each environment
# (Development / Preview / Production) — this file is not read by Vercel.

# Cloudflare Turnstile — Dashboard → Turnstile → your widget → Secret key
TURNSTILE_SECRET=

# Zitadel — PKCE OAuth (no client secret required for the hosted login flow)
# The callback URL "<NEXTAUTH_URL>/api/auth/callback/verbosec-account" must
# be registered as a redirect URI on this app in the Zitadel console for
# every domain that uses it (localhost for dev, mynexusai.com for prod).
ZITADEL_ISSUER=https://account.verbosec.com
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# Zitadel — Service User PAT for server-side v2 API calls (signup, forgot
# password). Create a Service User in the Zitadel console with an org-level
# user-manager role, generate a Personal Access Token, and paste it below.
# Server-only — never expose to the client.
ZITADEL_SERVICE_USER_TOKEN=
# Org ID new users should be created in.
ZITADEL_ORG_ID=

# NextAuth
# Local dev: http://localhost:3000
# Vercel Production environment: https://mynexusai.com (set explicitly, so
# the callback URL is deterministic and matches what's registered in Zitadel)
# Vercel Preview environments: leave unset — on Vercel (VERCEL=1 is set
# automatically) NextAuth derives the origin from the request's forwarded
# host when NEXTAUTH_URL is absent, so each preview gets a working callback
# without a per-deployment override.
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
